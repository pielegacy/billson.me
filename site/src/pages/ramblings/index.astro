---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import RamblingCard from "../../components/RamblingCard.astro";
import { siteConfig } from "../../site.config.ts";

const pageTitle = "Ramblings";

const ramblings = await getCollection("ramblings", ({ data }) => {
	return import.meta.env.PROD ? !data.draft : true;
});

const sortedRamblings = ramblings.sort(
	(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
---

<Layout title={pageTitle}>
	<div class="min-h-screen py-16 px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl mx-auto">
			<div class="mb-12">
				<a
					href="/"
					class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors"
				>
					<span aria-hidden="true">←</span>
					<span>Back home</span>
				</a>
			</div>

			<header class="mb-12 space-y-4">
				<h1
					class="text-4xl sm:text-5xl font-bold text-gray-900 tracking-tight"
				>
					Ramblings
				</h1>
				<p class="text-lg text-gray-600 max-w-xl">
					Fulfilling the Software Engineer requirement of having a
					blog.
				</p>
			</header>

			{
				sortedRamblings.length === 0 ? (
					<p class="text-gray-500 text-center py-12">
						No ramblings yet. Check back soon!
					</p>
				) : (
					<div class="space-y-4">
						{sortedRamblings.map((rambling) => (
							<RamblingCard rambling={rambling} />
						))}
					</div>
				)
			}
		</div>
	</div>
</Layout>
