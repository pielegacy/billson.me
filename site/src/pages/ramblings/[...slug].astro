---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../site.config.ts";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
	const ramblings = await getCollection("ramblings");
	return ramblings.map((rambling) => ({
		params: { slug: rambling.id },
		props: { rambling },
	}));
}) satisfies GetStaticPaths;

const { rambling } = Astro.props;
const { Content } = await render(rambling);

const { title, description, publishedDate, updatedDate, tags, heroImage } =
	rambling.data;

const formattedPublishedDate = new Date(publishedDate).toLocaleDateString(
	"en-AU",
	{
		day: "numeric",
		month: "long",
		year: "numeric",
	},
);

const formattedUpdatedDate = updatedDate
	? new Date(updatedDate).toLocaleDateString("en-AU", {
			day: "numeric",
			month: "long",
			year: "numeric",
		})
	: null;

// Generate Article structured data for SEO
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description: description,
	author: {
		"@type": "Person",
		name: siteConfig.author.name,
	},
	datePublished: publishedDate.toISOString(),
	dateModified: updatedDate?.toISOString() || publishedDate.toISOString(),
	url: `${siteConfig.url}/ramblings/${rambling.id}`,
};
---

<Layout title={title} description={description}>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(articleSchema)}
	/>

	<div class="min-h-screen py-16 px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl mx-auto">
			<div class="mb-8">
				<a
					href="/ramblings"
					class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors"
				>
					<span aria-hidden="true">←</span>
					<span>All ramblings</span>
				</a>
			</div>

			<article>
				<header class="mb-8 space-y-4">
					<div class="flex items-center gap-2 text-sm text-gray-500">
						<time datetime={publishedDate.toISOString()}>
							{formattedPublishedDate}
						</time>
						{tags && tags.length > 0 && (
							<>
								<span>·</span>
								<span class="text-gray-400">
									{tags.join(", ")}
								</span>
							</>
						)}
					</div>

					<h1
						class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 tracking-tight leading-tight"
					>
						{title}
					</h1>

					{formattedUpdatedDate && (
						<p class="text-sm text-gray-400">
							Updated on <time datetime={updatedDate?.toISOString()}>
								{formattedUpdatedDate}
							</time>
						</p>
					)}
				</header>

				{heroImage && (
					<div class="mb-8">
						<Image
							src={heroImage}
							alt={`Hero image for ${title}`}
							width={1200}
							height={630}
							class="w-full rounded-lg shadow-lg object-cover"
						/>
					</div>
				)}

				<div class="prose prose-lg prose-gray max-w-none">
					<Content />
				</div>
			</article>

			<footer class="mt-12 pt-8 border-t border-gray-200">
				<div class="flex items-center justify-between">
					<a
						href="/ramblings"
						class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors"
					>
						<span aria-hidden="true">←</span>
						<span>All ramblings</span>
					</a>
					<div class="flex items-center gap-2">
						{tags?.map((tag) => (
							<span class="px-3 py-1 text-sm bg-gray-100 text-gray-600 rounded-full">
								{tag}
							</span>
						))}
					</div>
				</div>
			</footer>
		</div>
	</div>
</Layout>
