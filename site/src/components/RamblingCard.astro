---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	rambling: CollectionEntry<"ramblings">;
}

const { rambling } = Astro.props;
const { title, description, publishedDate, tags } = rambling.data;

const formattedDate = new Date(publishedDate).toLocaleDateString("en-AU", {
	day: "numeric",
	month: "long",
	year: "numeric",
});
---

<article
	class="group bg-white/50 hover:bg-white/70 rounded-lg p-6 transition-colors duration-200 ease-in-out"
>
	<a href={`/ramblings/${rambling.id}`} class="block">
		<div class="space-y-2">
			<div class="flex items-center gap-2 text-sm text-gray-500">
				<time datetime={publishedDate.toISOString()}>{formattedDate}</time>
				{tags && tags.length > 0 && (
					<>
						<span>·</span>
						<span class="text-gray-400">
							{tags.join(", ")}
						</span>
					</>
				)}
			</div>
			<h2
				class="text-xl font-semibold text-gray-900 group-hover:text-gray-700 underline"
			>
				{title}
			</h2>
			<p class="text-gray-600 line-clamp-2">
				{description}
			</p>
		</div>
	</a>
</article>
