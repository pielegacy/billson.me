---
import "../styles/global.css";
interface Props {
	title?: string;
}

const { title = "Alex Billson" } = Astro.props;
const currentYear = new Date().getFullYear();
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body
		class="bg-[#EDF2E8] text-gray-800 font-sans antialiased min-h-screen flex flex-col"
	>
		<main class="flex-grow">
			<slot />
		</main>
		<footer class="py-6 text-center">
			<samp class="text-sm text-gray-500">
				powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-700">Astro</a>
			</samp>
		</footer>
	</body>
</html>
